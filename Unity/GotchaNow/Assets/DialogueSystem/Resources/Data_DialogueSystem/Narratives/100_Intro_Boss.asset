    <TargetNodeGuid>k__BackingField: acf0028f-5398-463f-a97f-ebdf8e87f9b1
  - <BaseNodeGuid>k__BackingField: 91a1f160-0a63-4b8a-b74d-aed94a12cd92
    <PortName>k__BackingField: Don't like fighting?
    <TargetNodeGuid>k__BackingField: 0a27da67-5dfc-4477-8d0b-40866f563bd6
  - <BaseNodeGuid>k__BackingField: acf0028f-5398-463f-a97f-ebdf8e87f9b1
