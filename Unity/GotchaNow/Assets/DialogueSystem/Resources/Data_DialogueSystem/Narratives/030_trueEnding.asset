  m_Name: 030_trueEnding
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSystem.Data.DialogueContainer
  <NodeLinks>k__BackingField:
  - <BaseNodeGuid>k__BackingField: 2b14ed88-14f8-47d2-a482-74bc2898e75e
