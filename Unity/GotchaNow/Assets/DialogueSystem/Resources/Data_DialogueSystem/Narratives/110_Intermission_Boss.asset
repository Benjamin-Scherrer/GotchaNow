  - guid: 1fb45fbd-0041-474f-80d6-726fe2a7c249
    dialogue:
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: "Hi nice to meet you! I'm Mephistopheles 15.\nI'm
        sorry, did I go too hard on you? \nI didn't mean it. "
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: "You know, i can be a little slower next time or
        something. \nI just got excited that i can fight again!"
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
