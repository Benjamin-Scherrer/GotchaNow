  - guid: 152f7072-88c6-4b06-9166-9c38cae3db22
    dialogue:
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: "No, Since our victims only see a limited view of
        this fight.\nI guess I'm not interesting enough. \nMaybe it's my design,
        you know."
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    position: {x: 756, y: 481.5}
