  - guid: 731bd0cf-7a9f-48f7-9f31-a4836d59569f
    dialogue:
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: "Oh you just get replaced. \nYou know if the player
        buys more lootboxes,\nthey probably will get a character that they prefer."
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: "And then you will not be played anymore.\LAs a Boss
        I can't get permanently benched but you...\nmaybe."
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
