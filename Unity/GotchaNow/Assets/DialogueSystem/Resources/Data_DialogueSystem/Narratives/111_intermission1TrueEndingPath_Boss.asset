    isCheckpoint: 0
    disableAlreadyChosenOptions: 0
  - guid: 7af82c1e-5b15-4692-a719-5e1a3ea913a2
    dialogue:
    - <CharacterName>k__BackingField: Katoro
      <Content>k__BackingField: But if you ask me, that was a fun battle. I look
        forward to fighting you again.
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    position: {x: 709.5, y: 200}
    transitionNode: 0
