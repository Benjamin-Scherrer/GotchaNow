      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    - <CharacterName>k__BackingField: Boss
      <Content>k__BackingField: The boss lady can get scary, you know.
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    position: {x: 595.5, y: 200}
