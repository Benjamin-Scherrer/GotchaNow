  - guid: 9e6f961a-2cbe-4cf2-b216-301a6bf3be0c
    dialogue:
    - <CharacterName>k__BackingField: Katoro
      <Content>k__BackingField: Hi co-worker. I am glad you are a strong rival and
        not helpless.
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    - <CharacterName>k__BackingField: Katoro
      <Content>k__BackingField: Aya got mad. Please do not let her hurt you.
      <HideCharacter>k__BackingField: 0
      <DialogueEvent>k__BackingField:
        m_PersistentCalls:
          m_Calls: []
    position: {x: 280, y: 200}
    transitionNode: 1
