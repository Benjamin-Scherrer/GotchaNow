    <TargetNodeGuid>k__BackingField: 1f7103d6-8fa2-4929-9ece-edf31f3ec36f
  - <BaseNodeGuid>k__BackingField: adbb1244-9843-44b0-9e95-517a8918a1c4
    <PortName>k__BackingField: I know everything.
    <TargetNodeGuid>k__BackingField: 03e94f63-c185-4c6d-976d-e015775a6b3a
  - <BaseNodeGuid>k__BackingField: 1f7103d6-8fa2-4929-9ece-edf31f3ec36f
